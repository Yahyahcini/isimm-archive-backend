{
  "kind": "collectionType",
  "collectionName": "resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "Cours",
        "Examens",
        "TP",
        "TD",
        "Correction",
        "Projet"
      ]
    },
    "file": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "files"
      ]
    },
    "subject": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subject.subject",
      "inversedBy": "resources"
    },
    "approvalStatus": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ]
    },
    "resource": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::resource.resource",
      "inversedBy": "correction"
    },
    "correction": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::resource.resource",
      "mappedBy": "resource"
    }
  }
}

            "target": "api::level.level",
            "inversedBy": "subjects"
        },
        "semester": {
            "type": "enumeration",
            "required": true,
            "enum": [
                "Semestre 1",
                "Semestre 2"
            ]
        },
        "resources": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::resource.resource",
            "mappedBy": "subject"
        }
    }
}

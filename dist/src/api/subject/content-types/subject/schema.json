{
    "kind": "collectionType",
    "collectionName": "subjects",
    "info": {
        "singularName": "subject",
        "pluralName": "subjects",
        "displayName": "Subject"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {

{
    "kind": "collectionType",
    "collectionName": "levels",
    "info": {
        "singularName": "level",
        "pluralName": "levels",
        "displayName": "Level"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "degree": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::degree.degree",
            "inversedBy": "levels"
        },
        "order": {
            "type": "integer"
        },
        "subjects": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::subject.subject",
            "mappedBy": "level"
        }
    }
}
